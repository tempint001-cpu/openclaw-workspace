w\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"Read /root/.openclaw/workspace/CRON-CONTEXT.md. Send the following exact message to the Nrexya group using message(action=send, channel=telegram, target=-1003606834639): '🌅 Good morning, Nrexya! \\\\n\\\\nToday is April 27 — exam day! Wishing everyone the best, especially those with exams. You've prepared well, go crush it! 💪\\\\n\\\\nHave a great Saturday! 🖤'\",\n        \"model\": \"kilocode/kilo-auto/free\"\n      },\n      \"delivery\": {\n        \"mode\": \"none\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1777257000000\n      }\n    }\n  ],\n  \"total\": 13,\n  \"offset\": 0,\n  \"limit\": 13,\n  \"hasMore\": false,\n  \"nextOffset\": null\n}"}],"details":{"jobs":[{"id":"eeef1692-7e97-45f3-ad50-814f0afcae29","agentId":"main","sessionKey":"agent:main:telegram:direct:7924461837","name":"heartbeat-health-monitor","enabled":true,"createdAtMs":1775415426580,"updatedAtMs":1775462486643,"schedule":{"kind":"cron","expr":"0 * * * *","tz":"UTC","staggerMs":300000},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"python3 ~/.openclaw/workspace/scripts/heartbeat_health_cron.py"},"delivery":{"mode":"announce","channel":"telegram","to":"7924461837"},"state":{"nextRunAtMs":1775466038099,"lastRunAtMs":1775462438104,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":48539,"lastDelivered":true,"lastDeliveryStatus":"delivered","consecutiveErrors":0}},{"id":"acac777d-d3ee-49e8-8cc4-e7960e30362a","agentId":"main","sessionKey":"agent:main:telegram:direct:7924461837","name":"feminine-tip-daily","enabled":true,"createdAtMs":1775409875117,"updatedAtMs":1775409875117,"schedule":{"kind":"cron","expr":"0 15 * * *","tz":"Asia/Kolkata"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"Read /root/.openclaw/workspace/feminine-tips.txt. Choose one tip (any). Send it to the Nrexya group using message(action=send, channel=