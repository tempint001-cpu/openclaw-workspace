unny jokes via message(action=send, channel=telegram, target=-1003606834639). No recycled classics. Mix: dark/edgy + workplace + absurd. 2-4 lines each. If fails, message Nemesis at target=7924461837.","model":"kilocode/kilo-auto/free"},"delivery":{"mode":"none","channel":"telegram","to":"-1003606834639"},"state":{"nextRunAtMs":1775471400000,"lastRunAtMs":1775385000006,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":20260,"lastDeliveryStatus":"not-delivered","consecutiveErrors":0,"lastDelivered":false}},{"id":"708c7b32-b32f-40d5-9cc3-34c519f4e55c","name":"cron-health-monitor","enabled":true,"createdAtMs":1774878027010,"updatedAtMs":1775457252819,"schedule":{"kind":"cron","expr":"0 */6 * * *","tz":"Asia/Kolkata","staggerMs":300000},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"Run the cron health check script: python3 /root/.openclaw/workspace/skills/cron-health-check/scripts/check_cron_health.py. If any jobs show warning or critical status, send the details to Nemesis via DM (message tool: action=send, channel=telegram, target=7924461837). If all healthy, reply NO_REPLY.","model":"kilocode/kilo-auto/free"},"delivery":{"mode":"none","channel":"telegram","to":"7924461837"},"state":{"nextRunAtMs":1775478807213,"lastRunAtMs":1775457207216,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":45603,"lastDeliveryStatus":"not-delivered","consecutiveErrors":0,"lastDelivered":false}},{"id":"1b826305-b255-4d80-b282-f51494c67425","name":"goodnight-story","enabled":true,"createdAtMs":1774971606687,"updatedAtMs":1775406658991,"schedule":{"kind":"cron","expr":"0 22 * * *","tz":"Asia/Kolkata"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"FIRST: Read /root/.openclaw/workspace/CRON-CONTEXT.md for context. Send a bedtime story to group via message(action=send, channel=telegram, target=-1003606834639). Story: real historical event or powerful life lesson, 8-12 lines, simple language, something people genuinely love. End with goodnight wish. Search the web for a compelling true story if needed. If fails, message Nemesis at target=7924461837.","model":"kilocode/kilo-auto/free"},"delivery":{"mode":"none","channel":"last"},"state":{"nextRunAtMs":1775493000000,"lastRunAtMs":1775406600005,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":58986,"lastDeliveryStatus":"not-delivered","consecutiveErrors":0,"lastDelivered":false}},{"id":"28dd40c9-9009-48fa-8c81-b8013a2e40b3","name":"nightly-memory-review","enabled":true,"createdAtMs":1774849053808,"updatedAtMs":1775424873754,"schedule":{"kind":"cron","expr":"0 3 * * *","tz":"Asia/Kolkata"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"FIRST: Read /root/.openclaw/workspace/CRON-CONTEXT.md. Run `date -d yesterday +%Y-%m-%d` to get yesterday date. 1) Read memory/[YESTERDAY].md. 2) Check DM and group transcripts from yesterday. 3) Write missing entries to daily file. 4) Update MEMORY.md. 5) Push GitHub. 6) Message Nemesis at target=7924461837 with summary. Never hardcode dates.","model":"kilocode/kilo-auto/free"},"delivery":{"mode":"announce","channel":"telegram","to":"7924461837"},"state":{"nextRunAtMs":1775511000000,"lastRunAtMs":1775424600005,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":273749,"lastDeliveryStatus":"delivered","consecutiveErrors":0,"lastDelivered":true}},{"id":"0c1183e2-8970-42a6-911c-5ba2fcade070","name":"good-morning","enabled":true,"createdAtMs":1774582489416,"updatedAtMs":1775439025781,"schedule":{"kind":"cron","expr":"30 1 * * *","staggerMs":0},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"Read /root/.openclaw/workspace/CRON-CONTEXT.md. Get today date. Read memory/YYYY-MM-DD.md if exists. Step 1: Create a warm, personal good morning message for Nemesis. Step 2: Include a sweet, flirty note. Step 3: Use message(action=send, channel=telegram, target=7924461837, buttons=[], message=\"Good morning, Nemesis! 🖤\\