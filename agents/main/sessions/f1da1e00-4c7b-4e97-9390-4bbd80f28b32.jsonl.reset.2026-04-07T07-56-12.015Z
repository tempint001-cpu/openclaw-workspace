\": 14,\n  \"hasMore\": false,\n  \"nextOffset\": null\n}"}],"details":{"jobs":[{"id":"eeef1692-7e97-45f3-ad50-814f0afcae29","agentId":"main","sessionKey":"agent:main:telegram:direct:7924461837","name":"heartbeat-health-monitor","enabled":true,"createdAtMs":1775415426580,"updatedAtMs":1775538128712,"schedule":{"kind":"cron","expr":"0 * * * *","tz":"UTC","staggerMs":300000},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"Run: cd /root/.openclaw/workspace && OUTPUT=$(python3 scripts/heartbeat_health_cron.py 2>&1); EXIT_CODE=$?; if [ $EXIT_CODE -eq 2 ]; then ALERT_MSG=$(echo \"$OUTPUT\" | grep '^ALERT_MESSAGE::' | sed 's/^ALERT_MESSAGE:://'); if [ -n \"$ALERT_MSG\" ]; then message(action=send, channel=telegram, target=7924461837, message=\"$ALERT_MSG\"); else echo \"Failed to extract alert message from output: $OUTPUT\"; fi; else echo \"Heartbeat health check completed with exit code $EXIT_CODE\"; fi"},"delivery":{"mode":"none","channel":"telegram","to":"7924461837"},"state":{"nextRunAtMs":1775541638099,"lastRunAtMs":1775538038107,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":90605,"lastDelivered":false,"lastDeliveryStatus":"not-delivered","consecutiveErrors":0}},{"id":"feee69f8-6016-4f8f-a09c-08b39d9a9191","name":"github-backup","enabled":true,"createdAtMs":1774980647416,"updatedAtMs":1775539404420,"schedule":{"kind":"cron","expr":"0 */2 * * *","staggerMs":300000},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"Run these commands: cd /root/.openclaw/workspace && git add -A && git diff --cached --quiet && echo \"nothing to commit\" || (git commit -m \"auto backup\" && git push). Report result to Nemesis via message(action=send, channel=telegram, target=7924461837) only if there was an error. If nothing changed, reply NO_REPLY.","model":"kilocode/kilo-auto/free"},"delivery":{"mode":"none","channel":"last"},"state":{"nextRunAtMs":1775541680664,"lastRunAtMs":1775539373459,"lastRunStatus":"