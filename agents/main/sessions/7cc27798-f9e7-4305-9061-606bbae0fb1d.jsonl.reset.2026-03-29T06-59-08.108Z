 \\\"145272a0-f193-4723-94f5-38dada60c1f0\\\",\\n  \\\"name\\\": \\\"good-morning\\\",\\n  \\\"description\\\": \\\"Daily good morning with good news + philosophical question at 8am IST\\\",\\n  \\\"enabled\\\": true,\\n  \\\"createdAtMs\\\": 1774678083814,\\n  \\\"updatedAtMs\\\": 1774753325110,\\n  \\\"schedule\\\": {\\n    \\\"kind\\\": \\\"cron\\\",\\n    \\\"expr\\\": \\\"0 8 * * *\\\",\\n    \\\"tz\\\": \\\"Asia/Kolkata\\\",\\n    \\\"staggerMs\\\": 0\\n  },\\n  \\\"sessionTarget\\\": \\\"isolated\\\",\\n  \\\"wakeMode\\\": \\\"now\\\",\\n  \\\"payload\\\": {\\n    \\\"kind\\\": \\\"agentTurn\\\",\\n    \\\"message\\\": \\\"Send a warm, lovely good morning message to the Nrexya group. Be cheerful, creative, and vary it each day. Use nice emojis. Then include: (1) A brief \\\\\\\"Good News\\\\\\\" section with 3-4 positive/interesting news items from today — search the web for real uplifting news. (2) A \\\\\\\"Brain Teaser\\\\\\\" section with one short philosophical or thought-provoking question to get the group thinking. Keep the whole message engaging, not too long.\\\"\\n  },\\n  \\\"delivery\\\": {\\n    \\\"mode\\\": \\\"announce\\\",\\n    \\\"channel\\\": \\\"telegram\\\",\\n    \\\"to\\\": \\\"-1003606834639\\\"\\n  },\\n  \\\"state\\\": {\\n    \\\"nextRunAtMs\\\": 1774837800000,\\n    \\\"lastRunAtMs\\\": 1774751400009,\\n    \\\"lastRunStatus\\\": \\\"ok\\\",\\n    \\\"lastStatus\\\": \\\"ok\\\",\\n    \\\"lastDurationMs\\\": 14973,\\n    \\\"lastDelivered\\\": true,\\n    \\\"lastDeliveryStatus\\\": \\\"delivered\\\",\\n    \\\"consecutiveErrors\\\": 0\\n  }\\n}\",\"_meta\":{\"runtime\":\"node\",\"runtimeVersion\":\"22.22.1\",\"hostname\":\"unknown\",\"name\":\"openclaw\",\"date\":\"2026-03-29T03:02:05.119Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///usr/local/lib/node_modules/openclaw/dist/subsystem-BDbeCphF.js:944:46\",\"fileName\":\"subsystem-BDbeCphF.js\",\"fileNameWithLine\":\"subsystem-BDbeCphF.js:944\",