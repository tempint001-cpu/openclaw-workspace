  },
  "update": {
    "checkOnStart": false
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true
  },
  "auth": {
    "profiles": {
      "kilocode:default": {
        "provider": "kilocode",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "mode": "merge"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "kilocode/bytedance-seed/dola-seed-2.0-pro:free"
      },
      "workspace": "/root/.openclaw/workspace",
      "memorySearch": {
        "sources": [
          "memory"
        ],
        "experimental": {
          "sessionMemory": false
        },
        "provider": "gemini",
        "remote": {
          "apiKey": "AIzaSyB2-QmeVouz3kLfji00m2DNLqlpFiTuTEE"
        },
        "fallback": "none",
        "model": "gemini-embedding-001",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        },
        "cache": {
          "enabled": true,
          "maxEntries": 50000
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "30m",
        "keepLastAssistants": 3
      },
      "compaction": {
        "reserveTokensFloor": 20000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000,
          "prompt": "Write any lasting notes to memory/YYYY-MM-DD.md. If there's nothing to store, respond with OK only.",
          "systemPrompt": "Session nearing compaction. Store durable memories now."
        }
      },
      "heartbeat": {
        "every": "30m",
        "activeHours": {
          "start": "07:00",
          "end": "23:00",
          "timezone": "Asia/Kolkata"
        },
        "target": "last",
        "lightContext": true
      }
    }
  },
  "tools": {
    "profile": "full",
    "web": {
      "search": {
        "enabled": true,
        "provider": "gemini"
      }
    },
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
