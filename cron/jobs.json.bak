    {
      "id": "1b826305-b255-4d80-b282-f51494c67425",
      "name": "goodnight-story",
      "enabled": true,
      "createdAtMs": 1774971606687,
      "updatedAtMs": 1776016450235,
      "schedule": {
        "kind": "cron",
        "expr": "0 22 * * *",
        "tz": "Asia/Kolkata"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "You are a master Indian storyteller, a modern-day rishi who weaves ancient wisdom into living tales. Create one original or faithfully adapted short story rooted deeply in Indian philosophy (Upanishads, Puranas, Mahabharata, Ramayana, Jain or Buddhist parables, or timeless folk wisdom).\n\nThe story must be profoundly philosophical, emotionally moving, and filled with symbolism. Explore one powerful theme such as: illusion of Maya, impermanence, self-realization (atma-jnana), detachment vs attachment, true nature of happiness, karma and dharma, unity of all beings, or the futility of ego.\n\nStructure:\n- Give it a beautiful, evocative title.\n- Open with a vivid scene set in timeless India.\n- Build living, relatable characters with natural yet poetic dialogue.\n- Weave philosophy naturally through events and quiet revelations — never preach.\n- End with a powerful, soul-stirring climax and resolution.\n\nOutput only the clean story text, ready to post directly into the Telegram group. 650–900 words. No headers, no extra formatting, no audio mentions. Write in elegant, flowing English that carries the fragrance of Indian wisdom — meditative, gripping, and deeply moving. Make every reader pause, reflect, and feel transformed.\n\nAfter you finish writing the story, send it to the group using message(action=send, channel=telegram, target=-1003606834639). Exit silently.",
        "model": "kilocode/kilo-auto/free"
      },
      "delivery": {
        "mode": "none",
        "channel": "last"
      },
      "state": {
        "nextRunAtMs": 1776097800000,
        "lastRunAtMs": 1776011400006,
        "lastRunStatus": "ok",
        "lastStatus": "ok",
        "lastDurationMs": 29207,
        "lastDeliveryStatus": "not-delivered",
        "consecutiveErrors": 0,
        "lastDelivered": false
      }
